<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 기본 콘솔 appender (프로파일 활성화 전에도 동작) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss:SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 기본 root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- ==================== 개발 환경 (local, dev) ==================== -->
    <springProfile name="local,dev">
        <root level="info">
            <appender-ref ref="CONSOLE" />
        </root>

        <!-- 내 프로젝트: DEBUG -->
        <logger name="com.sprint.mission.discodeit" level="DEBUG" />

        <!-- Hibernate 전체: INFO (내부 동작 로그 숨김) -->
        <logger name="org.hibernate" level="INFO" />

        <!-- SQL 쿼리 -->
        <logger name="org.hibernate.SQL" level="DEBUG" />
        <!-- SQL 파라미터 -->
        <logger name="org.hibernate.orm.jdbc.bind" level="DEBUG" />
        <!-- 결과 그래프만 DEBUG -->
        <logger name="org.hibernate.orm.results.graph" level="DEBUG" />

    </springProfile>

    <!-- ==================== 운영 환경 (prod) ==================== -->
    <springProfile name="prod">
        <!-- 파일 출력 -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/.logs/application.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>/.logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>10GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss:SSS} %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <!-- ERROR 로그 별도 파일 -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/.logs/error.log</file>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>ERROR</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>/.logs/error.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss:SSS} %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="DEBUG">
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>

        <!-- 운영 환경에서는 SQL 로그 최소화 -->
        <logger name="org.hibernate.SQL" level="WARN" />
        <logger name="org.springframework" level="WARN" />
    </springProfile>

</configuration>
